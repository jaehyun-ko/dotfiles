# Dotfiles sync defaults (repo-managed, non-secret)
DOTFILES_SYNC_CONTROLLER=false
DOTFILES_AUTO_UPDATE_REMOTE=origin
DOTFILES_AUTO_UPDATE_BRANCH=main
# DOTFILES_SYNC_POST_CMD is intentionally unset.
# dotfiles-sync defaults to repo-managed post actions:
#   opencode-config-sync --force && codex-config-sync && omx-config-sync
DOTFILES_SYNC_RETRY_MAX=3
DOTFILES_SYNC_RETRY_BASE_SEC=2
