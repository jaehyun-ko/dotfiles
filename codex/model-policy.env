# Codex model policy (repo-managed defaults)
# Override per host with:
#   overlays/<server_id>/codex/model-policy.env

# General/default interactive sessions
DEFAULT_MODEL="gpt-5.5"
DEFAULT_REASONING_EFFORT="xhigh"

# Planning-first sessions
PLAN_MODEL="gpt-5.5"
PLAN_REASONING_EFFORT="xhigh"

# Implementation / code feedback sessions
CODE_MODEL="gpt-5.5"
CODE_REASONING_EFFORT="xhigh"
