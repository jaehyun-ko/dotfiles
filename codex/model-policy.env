# Codex model routing policy (repo-managed defaults)
# Override per host with:
#   overlays/<server_id>/codex/model-policy.env

# General chat/search/default interactive sessions
DEFAULT_MODEL="gpt-5.2"
DEFAULT_REASONING_EFFORT="medium"

# Planning-first sessions
PLAN_MODEL="gpt-5.2"
PLAN_REASONING_EFFORT="xhigh"

# Implementation / code feedback sessions
CODE_MODEL="gpt-5.3-codex"
CODE_REASONING_EFFORT="high"
