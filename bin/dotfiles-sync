#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    if [[ "$source" != /* ]]; then
      source="$dir/$source"
    fi
  done
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
DEFAULT_REPO="$(cd "$SCRIPT_DIR/.." && pwd)"

DOTFILES_REPO="${DOTFILES_REPO:-$DEFAULT_REPO}"
DOTFILES_REMOTE="${DOTFILES_REMOTE:-origin}"
DOTFILES_BRANCH="${DOTFILES_BRANCH:-main}"
DRY_RUN=0

show_help() {
  cat <<'EOF'
Usage: dotfiles-sync [OPTIONS]

Options:
  --repo PATH               Local dotfiles repository path
  --remote NAME             Git remote name to pull from
  --branch NAME             Branch to pull
  --dry-run                 Print actions without applying
  --help, -h                Show this help
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      DOTFILES_REPO="$2"
      shift 2
      ;;
    --remote)
      DOTFILES_REMOTE="$2"
      shift 2
      ;;
    --branch)
      DOTFILES_BRANCH="$2"
      shift 2
      ;;
    --servers|--remote-path|--user|--ssh-port|--identity|--post-cmd)
      printf '[warn] option %s is deprecated and ignored (pull-based sync only)\n' "$1" >&2
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
  *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

require_repo_state() {
  local repo="$1"

  if ! git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "[skip] not a git repo: $repo" >&2
    return 1
  fi

  if ! git -C "$repo" remote get-url "$DOTFILES_REMOTE" >/dev/null 2>&1; then
    echo "[skip] remote not found: $DOTFILES_REMOTE" >&2
    return 1
  fi

  if ! git -C "$repo" diff --quiet --ignore-submodules --; then
    echo "[skip] repo has unstaged changes: $repo" >&2
    return 1
  fi

  if ! git -C "$repo" diff --cached --quiet --ignore-submodules --; then
    echo "[skip] repo has staged changes: $repo" >&2
    return 1
  fi

  if [ -n "$(git -C "$repo" ls-files --others --exclude-standard)" ]; then
    echo "[skip] repo has untracked files: $repo" >&2
    return 1
  fi

  return 0
}

if ! require_repo_state "$DOTFILES_REPO"; then
  exit 0
fi

before="$(git -C "$DOTFILES_REPO" rev-parse --short HEAD)"

if [[ "$DRY_RUN" == "1" ]]; then
  echo "[dry-run] would run: git -C \"$DOTFILES_REPO\" pull --ff-only \"$DOTFILES_REMOTE\" \"$DOTFILES_BRANCH\""
else
  if ! git -C "$DOTFILES_REPO" pull --ff-only "$DOTFILES_REMOTE" "$DOTFILES_BRANCH"; then
    echo "[error] dotfiles pull failed for $DOTFILES_REPO" >&2
    exit 1
  fi
fi

after="$(git -C "$DOTFILES_REPO" rev-parse --short HEAD)"

if [[ "$before" == "$after" ]]; then
  echo "[ok] dotfiles already up to date ($after)"
else
  echo "[ok] dotfiles updated: $before -> $after"
fi
