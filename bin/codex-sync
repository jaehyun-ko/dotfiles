#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    if [[ "$source" != /* ]]; then
      source="$dir/$source"
    fi
  done
  cd -P "$(dirname "$source")" && pwd
}

LAUNCHER_DIR="$(resolve_script_dir)"

CODEX_BIN="${CODEX_BIN:-codex}"
CODEX_CONFIG_SYNC_BIN="${CODEX_CONFIG_SYNC_BIN:-$LAUNCHER_DIR/codex-config-sync}"

if [[ -x "$CODEX_CONFIG_SYNC_BIN" ]] || command -v "$CODEX_CONFIG_SYNC_BIN" >/dev/null 2>&1; then
  if ! "$CODEX_CONFIG_SYNC_BIN"; then
    echo "[warn] codex config sync failed; continuing launch." >&2
  fi
fi

exec "$CODEX_BIN" "$@"
