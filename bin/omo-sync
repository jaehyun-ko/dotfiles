#!/usr/bin/env bash
set -euo pipefail

OPENCODE_CONFIG_SYNC_BIN="${OPENCODE_CONFIG_SYNC_BIN:-opencode-config-sync}"
OMO_BIN="${OMO_BIN:-oh-my-opencode}"

if command -v "$OPENCODE_CONFIG_SYNC_BIN" >/dev/null 2>&1; then
  if ! "$OPENCODE_CONFIG_SYNC_BIN"; then
    echo "[warn] opencode config sync failed; continuing launch." >&2
  fi
fi

exec "$OMO_BIN" "$@"
