#!/usr/bin/env bash
set -euo pipefail

show_help() {
  cat <<'EOF_HELP'
Usage: codex-config-sync [--check]

Options:
  --check     Validate configured values only, do not modify files
  --help, -h  Show this help
EOF_HELP
}

mode="sync"
while (($# > 0)); do
  case "$1" in
    --check)
      mode="check"
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
  shift
done

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    if [[ "$source" != /* ]]; then
      source="$dir/$source"
    fi
  done
  cd -P "$(dirname "$source")" && pwd
}

get_server_id() {
  if [[ -n "${DOTFILES_SERVER_ID:-}" ]]; then
    printf '%s' "$DOTFILES_SERVER_ID"
    return 0
  fi
  hostname -s 2>/dev/null || hostname
}

ensure_var() {
  local name="$1"
  local value="${!name:-}"
  if [[ -z "$value" ]]; then
    echo "[error] missing required policy variable: $name" >&2
    exit 1
  fi
}

toml_escape_value() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

ensure_toml_key() {
  local key="$1"
  local value="$2"
  local path="$3"
  local escaped_value expected_line tmp
  escaped_value="$(toml_escape_value "$value")"
  expected_line="$key = \"$escaped_value\""

  if grep -Eq "^[[:space:]]*${key}[[:space:]]*=" "$path"; then
    if [[ "$mode" == "check" ]]; then
      if ! awk -v key="$key" -v expected="$value" '
        BEGIN { ok = 0; pattern = "^[[:space:]]*" key "[[:space:]]*=" }
        {
          if ($0 ~ pattern) {
            line = $0
            sub(/^[[:space:]]*[^=]+=[[:space:]]*/, "", line)
            sub(/^[[:space:]]*"/, "", line)
            sub(/"[[:space:]]*$/, "", line)
            if (line == expected) {
              ok = 1
              exit
            }
          }
        }
        END { exit(ok ? 0 : 1) }
      ' "$path"; then
        echo "[missing] $key -> \"$value\"" >&2
        return 1
      fi
      return 0
    fi
    tmp="$(mktemp)"
    awk -v key="$key" -v line="$expected_line" '
      BEGIN { pattern = "^[[:space:]]*" key "[[:space:]]*=" }
      {
        if ($0 ~ pattern) {
          print line
          next
        }
        print
      }
    ' "$path" >"$tmp"
    mv "$tmp" "$path"
    return 0
  fi

  if [[ "$mode" == "check" ]]; then
    echo "[missing] $key -> \"$value\"" >&2
    return 1
  fi

  tmp="$(mktemp)"
  awk -v line="$expected_line" '
    BEGIN { inserted = 0 }
    /^[[:space:]]*\[/ && inserted == 0 {
      print line
      inserted = 1
    }
    { print }
    END {
      if (inserted == 0) {
        print line
      }
    }
  ' "$path" >"$tmp"
  mv "$tmp" "$path"
}

sync_multiline_toml_key_from_file() {
  local key="$1"
  local value_file="$2"
  local path="$3"

  if [[ ! -f "$value_file" ]]; then
    echo "[error] missing multiline value file: $value_file" >&2
    return 1
  fi

  if ! node - "$mode" "$key" "$value_file" "$path" <<'EOF_NODE'
const fs = require('fs');

const [, , mode, key, valueFile, configPath] = process.argv;

function escapeRegex(value) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function normalize(value) {
  return value.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
}

const desired = normalize(fs.readFileSync(valueFile, 'utf8')).replace(/\n$/, '');
if (desired.includes("'''")) {
  console.error(`[error] ${valueFile} contains an unsupported TOML literal delimiter`);
  process.exit(1);
}

const original = normalize(fs.readFileSync(configPath, 'utf8'));
const pattern = new RegExp(
  `^\\s*${escapeRegex(key)}\\s*=\\s*(['"]{3})\\n([\\s\\S]*?)\\n\\1`,
  'm',
);
const match = original.match(pattern);

if (mode === 'check') {
  if (!match || match[2] !== desired) {
    console.error(`[missing] ${key} -> ${valueFile}`);
    process.exit(1);
  }
  process.exit(0);
}

const replacement = `${key} = '''\n${desired}\n'''`;
let updated = original;

if (match) {
  updated = original.replace(pattern, replacement);
} else {
  const sectionMatch = original.match(/^\[[^\n]+\]/m);
  if (sectionMatch && sectionMatch.index !== undefined) {
    updated = `${original.slice(0, sectionMatch.index)}${replacement}\n\n${original.slice(sectionMatch.index)}`;
  } else {
    const trimmed = original.replace(/\s*$/, '');
    updated = trimmed ? `${trimmed}\n\n${replacement}\n` : `${replacement}\n`;
  }
}

if (updated !== original) {
  fs.writeFileSync(configPath, updated);
}
EOF_NODE
  then
    return 1
  fi
}

remove_toml_key() {
  local key="$1"
  local path="$2"

  node - "$mode" "$key" "$path" <<'EOF_NODE'
const fs = require('fs');

const [, , mode, key, configPath] = process.argv;

function escapeRegex(value) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function normalize(value) {
  return value.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
}

const original = normalize(fs.readFileSync(configPath, 'utf8'));
const keyPattern = escapeRegex(key);
const multiline = new RegExp(`^\\s*${keyPattern}\\s*=\\s*(['"]{3})\\n[\\s\\S]*?\\n\\1\\n?`, 'm');
const singleline = new RegExp(`^\\s*${keyPattern}\\s*=.*\\n?`, 'm');
let updated = original.replace(multiline, '').replace(singleline, '');
updated = updated.replace(/\n{3,}/g, '\n\n');

if (mode === 'check') {
  if (updated !== original) {
    console.error(`[stale] remove ${key}`);
    process.exit(1);
  }
  process.exit(0);
}

if (updated !== original) {
  fs.writeFileSync(configPath, updated);
}
EOF_NODE
}

script_dir="$(resolve_script_dir)"
dotfiles_dir="${DOTFILES_REPO:-$(cd "$script_dir/.." && pwd)}"
server_id="$(get_server_id)"

base_policy_path="$dotfiles_dir/codex/model-policy.env"
overlay_policy_path="$dotfiles_dir/overlays/$server_id/codex/model-policy.env"
policy_path="$base_policy_path"
if [[ -f "$overlay_policy_path" ]]; then
  policy_path="$overlay_policy_path"
fi

if [[ ! -f "$policy_path" ]]; then
  echo "[error] missing policy file: $policy_path" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$policy_path"

ensure_var "DEFAULT_MODEL"
ensure_var "DEFAULT_REASONING_EFFORT"
ensure_var "PLAN_REASONING_EFFORT"

codex_home="${CODEX_HOME:-$HOME/.codex}"
config_path="$codex_home/config.toml"

if [[ "$mode" == "sync" ]]; then
  mkdir -p "$codex_home"
  touch "$config_path"
fi

if [[ ! -f "$config_path" ]]; then
  echo "[error] missing codex config: $config_path" >&2
  exit 1
fi

status=0
ensure_toml_key "model" "$DEFAULT_MODEL" "$config_path" || status=1
ensure_toml_key "model_reasoning_effort" "$DEFAULT_REASONING_EFFORT" "$config_path" || status=1
ensure_toml_key "plan_mode_reasoning_effort" "$PLAN_REASONING_EFFORT" "$config_path" || status=1
remove_toml_key "developer_instructions" "$config_path" || status=1

if [[ "$status" -eq 0 && "$mode" == "sync" ]]; then
  echo "[ok] synced codex model-only policy: $config_path" >&2
fi

exit "$status"
