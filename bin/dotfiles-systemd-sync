#!/usr/bin/env bash
set -euo pipefail

show_help() {
  cat <<'EOF_HELP'
Usage: dotfiles-systemd-sync [--check]

Sync repo-managed user systemd units:
  - dotfiles-auto-update.timer/service
  - agentic-skill-updater.timer/service (optional)

Options:
  --check     Validate files only, do not modify
  --help, -h  Show this help
EOF_HELP
}

mode="sync"
while (($# > 0)); do
  case "$1" in
    --check)
      mode="check"
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
  shift
done

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    if [[ "$source" != /* ]]; then
      source="$dir/$source"
    fi
  done
  cd -P "$(dirname "$source")" && pwd
}

systemd_user_dir() {
  printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
}

sed_escape_replacement() {
  # Escape sed replacement chars: '&' and the chosen delimiter '|'.
  printf '%s' "$1" | sed -e 's/[&|]/\\&/g'
}

render_template() {
  local src="$1"
  local out="$2"
  shift 2

  local sed_args=()
  local pair key value
  for pair in "$@"; do
    key="${pair%%=*}"
    value="${pair#*=}"
    value="$(sed_escape_replacement "$value")"
    sed_args+=(-e "s|$key|$value|g")
  done

  sed "${sed_args[@]}" "$src" >"$out"
}

try_enable_linger() {
  [[ "$mode" == "sync" ]] || return 0
  command -v loginctl >/dev/null 2>&1 || return 0

  # Best-effort; OK to fail on locked-down systems.
  loginctl enable-linger "$USER" >/dev/null 2>&1 || true
}

systemctl_user_ok() {
  command -v systemctl >/dev/null 2>&1 || return 1
  systemctl --user show-environment >/dev/null 2>&1
}

sync_unit_pair() {
  local unit_name="$1"        # e.g. dotfiles-auto-update.timer
  local service_src="$2"
  local timer_src="$3"
  local service_dst="$4"
  local timer_dst="$5"
  shift 5

  local tmp_service changed="false"
  tmp_service="$(mktemp)"

  if [[ ! -f "$service_src" || ! -f "$timer_src" ]]; then
    rm -f "$tmp_service"
    echo "[skip] missing templates for $unit_name" >&2
    return 0
  fi

  render_template "$service_src" "$tmp_service" "$@"

  if [[ "$mode" == "check" ]]; then
    local ok=0
    if [[ ! -f "$service_dst" ]]; then
      echo "[missing] $service_dst" >&2
      ok=1
    elif ! cmp -s "$tmp_service" "$service_dst"; then
      echo "[diff] $service_dst" >&2
      ok=1
    fi

    if [[ ! -f "$timer_dst" ]]; then
      echo "[missing] $timer_dst" >&2
      ok=1
    elif ! cmp -s "$timer_src" "$timer_dst"; then
      echo "[diff] $timer_dst" >&2
      ok=1
    fi

    rm -f "$tmp_service"
    return "$ok"
  fi

  mkdir -p "$(dirname "$service_dst")"

  if [[ ! -f "$service_dst" ]] || ! cmp -s "$tmp_service" "$service_dst"; then
    cp "$tmp_service" "$service_dst"
    changed="true"
  fi

  if [[ ! -f "$timer_dst" ]] || ! cmp -s "$timer_src" "$timer_dst"; then
    cp "$timer_src" "$timer_dst"
    changed="true"
  fi

  rm -f "$tmp_service"

  if [[ "$changed" == "true" ]]; then
    systemctl --user daemon-reload >/dev/null 2>&1 || true
    systemctl --user enable --now "$unit_name" >/dev/null 2>&1 || true
    systemctl --user restart "$unit_name" >/dev/null 2>&1 || true
    echo "[ok] systemd unit synced: $unit_name" >&2
  fi

  return 0
}

main() {
  local script_dir dotfiles_dir user_dir
  script_dir="$(resolve_script_dir)"
  dotfiles_dir="${DOTFILES_REPO:-$(cd "$script_dir/.." && pwd)}"
  user_dir="$(systemd_user_dir)"

  if ! systemctl_user_ok; then
    echo "[skip] systemctl --user unavailable; skipping systemd sync" >&2
    return 0
  fi

  try_enable_linger

  local status=0

  # dotfiles auto-update timer/service (always).
  sync_unit_pair \
    "dotfiles-auto-update.timer" \
    "$dotfiles_dir/systemd/user/dotfiles-auto-update.service" \
    "$dotfiles_dir/systemd/user/dotfiles-auto-update.timer" \
    "$user_dir/dotfiles-auto-update.service" \
    "$user_dir/dotfiles-auto-update.timer" \
    "__DOTFILES_DIR__=$dotfiles_dir" || status=1

  # agentic skill updater is optional (requires the repo to exist).
  local agentic_repo="${AGENTIC_RESEARCHER_REPO:-$HOME/projects/agentic-researcher}"
  if [[ -f "$agentic_repo/scripts/skill_autoupdate.py" ]]; then
    local channel="${SKILL_SYNC_CHANNEL:-stable}"
    local canary="${SKILL_SYNC_CANARY_PERCENT:-10}"
    local install_root="${SKILL_SYNC_INSTALL_ROOT:-$HOME/.codex/skills}"
    local skill_name="${SKILL_SYNC_SKILL_NAME:-agentic-researcher}"

    sync_unit_pair \
      "agentic-skill-updater.timer" \
      "$dotfiles_dir/systemd/user/agentic-skill-updater.service" \
      "$dotfiles_dir/systemd/user/agentic-skill-updater.timer" \
      "$user_dir/agentic-skill-updater.service" \
      "$user_dir/agentic-skill-updater.timer" \
      "__REPO_DIR__=$agentic_repo" \
      "__CHANNEL__=$channel" \
      "__CANARY_PERCENT__=$canary" \
      "__INSTALL_ROOT__=$install_root" \
      "__SKILL_NAME__=$skill_name" || status=1
  else
    echo "[skip] agentic-researcher repo not found; skipping skill-updater timer" >&2
  fi

  return "$status"
}

main "$@"

