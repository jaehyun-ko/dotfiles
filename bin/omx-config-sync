#!/usr/bin/env bash
set -euo pipefail

show_help() {
  cat <<'EOF_HELP'
Usage: omx-config-sync [--check]

Remove legacy OMX prompt/agent/skill wiring from user-level Codex config.

Options:
  --check     Validate cleanup only, do not modify files
  --help, -h  Show this help
EOF_HELP
}

mode="sync"
while (($# > 0)); do
  case "$1" in
    --check)
      mode="check"
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
  shift
done

mark_stale() {
  local message="$1"
  echo "[stale] $message" >&2
}

remove_path() {
  local path="$1"

  if [[ "$mode" == "check" ]]; then
    if [[ -e "$path" || -L "$path" ]]; then
      mark_stale "$path"
      return 1
    fi
    return 0
  fi

  rm -rf "$path"
}

clean_codex_user_skills() {
  local skills_dir="${CODEX_HOME:-$HOME/.codex}/skills"
  local status=0

  [[ -d "$skills_dir" ]] || return 0

  while IFS= read -r -d '' path; do
    case "$(basename "$path")" in
      .system)
        continue
        ;;
    esac

    if [[ "$mode" == "check" ]]; then
      mark_stale "$path"
      status=1
    else
      rm -rf "$path"
    fi
  done < <(find "$skills_dir" -mindepth 1 -maxdepth 1 -print0)

  return "$status"
}

clean_codex_config() {
  local config_path="${CODEX_HOME:-$HOME/.codex}/config.toml"
  [[ -f "$config_path" ]] || return 0

  node - "$mode" "$config_path" <<'EOF_NODE'
const fs = require('fs');

const [, , mode, configPath] = process.argv;

function normalize(value) {
  return value.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
}

const original = normalize(fs.readFileSync(configPath, 'utf8'));
const lines = original.split('\n');
const sections = [];
let current = { name: null, header: null, lines: [] };

function pushCurrent() {
  sections.push(current);
}

for (const line of lines) {
  const header = line.match(/^\s*\[([^\]]+)\]\s*$/);
  if (header) {
    pushCurrent();
    current = { name: header[1], header: line, lines: [] };
  } else {
    current.lines.push(line);
  }
}
pushCurrent();

const output = [];

for (const section of sections) {
  if (section.name && section.name.startsWith('agents.')) {
    continue;
  }

  let body = section.lines;
  if (section.name === 'features') {
    body = body.filter((line) => !/^\s*(multi_agent|child_agents_md)\s*=/.test(line));
    const hasContent = body.some((line) => line.trim() && !line.trim().startsWith('#'));
    if (!hasContent) {
      continue;
    }
  }

  if (section.header !== null) {
    output.push(section.header);
  }
  output.push(...body);
}

let updated = output.join('\n').replace(/\n{3,}/g, '\n\n');
if (original.endsWith('\n') && !updated.endsWith('\n')) {
  updated += '\n';
}

if (mode === 'check') {
  if (updated !== original) {
    console.error('[stale] Codex OMX config wiring');
    process.exit(1);
  }
  process.exit(0);
}

if (updated !== original) {
  fs.writeFileSync(configPath, updated);
}
EOF_NODE
}

status=0

remove_path "${CODEX_HOME:-$HOME/.codex}/prompts" || status=1
remove_path "${CODEX_HOME:-$HOME/.codex}/rules" || status=1
remove_path "${CODEX_HOME:-$HOME/.codex}/AGENTS.md" || status=1
remove_path "${CODEX_HOME:-$HOME/.codex}/.omx-config.json" || status=1
clean_codex_user_skills || status=1
remove_path "$HOME/.omx/agents" || status=1
remove_path "$HOME/.agents/skills" || status=1
clean_codex_config || status=1

if [[ "$status" -eq 0 && "$mode" == "sync" ]]; then
  echo "[ok] removed legacy OMX prompt wiring" >&2
fi

exit "$status"
